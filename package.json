{
  "name": "ilnostroblog",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build:compile": "next build",
    "build:sitemap": "next-sitemap --config next-sitemap.config.js",
    "build": "yarn lint:fix && yarn build:compile && yarn build:sitemap",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "eslint --ext ts,tsx . --quiet",
    "lint:fix": "eslint --fix --ext ts,tsx .",
    "prettier:fix": "prettier --write ."
  },
  "dependencies": {
    "@sentry/nextjs": "^9.11.0",
    "@types/node": "^22.13.14",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "airtable": "^0.12.2",
    "contentful": "^11.5.1",
    "dotenv": "^16.4.7",
    "next": "15.2.5",
    "next-seo": "^6.6.0",
    "react": "18.3.1",
    "react-dom": "18.3.0",
    "react-is": "18.3.1",
    "styled-components": "^6.1.16",
    "typescript": "^5.8.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/eslint-parser": "7.25.0",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "7.23.0",
    "@cypress/request": "3.0.8",
    "@eslint/js": "^9.23.0",
    "@next/eslint-plugin-next": "^15.2.4",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@types/styled-components": "5.1.34",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "cypress": "14.2.1",
    "eslint": "^9.23.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-jibe": "^1.0.6",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-html": "^8.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-import-helpers": "^2.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-next": "^0.0.0",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^0.12.0",
    "globals": "^16.0.0",
    "lint-staged": "^15.5.0",
    "next-sitemap": "^4.2.3",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.28.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      [
        "eslint",
        "prettier --write"
      ],
      "git add"
    ],
    "**/*.{md,mdx,json}": [
      [
        "eslint",
        "prettier --write"
      ],
      "git add"
    ]
  },
  "resolutions": {
    "styled-components": "5",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "packageManager": "yarn@4.6.0"
}
