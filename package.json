{
  "name": "andrea-agostini-website",
  "version": "1.12.0",
  "private": true,
  "scripts": {
    "build": "yarn lint:fix && yarn build:compile && yarn build:sitemap",
    "build-storybook": "storybook build",
    "build:compile": "next build",
    "build:config": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:sitemap": "NODE_OPTIONS='--no-deprecation' next-sitemap --config next-sitemap.config.mjs",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --build-script-name build-storybook --exit-zero-on-changes",
    "dev": "NODE_OPTIONS='--no-deprecation' next dev --webpack",
    "e2e": "playwright test",
    "lhci": "lhci autorun",
    "lint": "eslint --ext ts,tsx . --quiet",
    "lint:fix": "eslint --fix --ext ts,tsx .",
    "postbuild": "NODE_OPTIONS='--no-deprecation' next-sitemap --config next-sitemap.config.mjs",
    "prettier:fix": "prettier --write .",
    "reset": "npx rimraf .yarn yarn.lock node_modules && touch yarn.lock && yarn install",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:update": "jest --updateSnapshot",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/context-async-hooks": "2.7.1",
    "@opentelemetry/core": "2.7.1",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@supabase/supabase-js": "^2.110.0",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "contentful": "11.12.1",
    "dotenv": "17.4.2",
    "next": "16.2.5",
    "next-seo": "6.8.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-is": "19.2.6",
    "styled-components": "6.4.1",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.2",
    "@eslint/js": "10.0.1",
    "@jest/globals": "^29.7.0",
    "@jest/types": "^29.6.3",
    "@lhci/cli": "^0.15.1",
    "@next/eslint-plugin-next": "16.2.5",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-links": "10.4.1",
    "@storybook/addon-onboarding": "10.3.6",
    "@storybook/nextjs": "10.3.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/identity-obj-proxy": "^3",
    "@types/jest": "^29.5.14",
    "@types/styled-components": "5.1.36",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "chromatic": "16.9.1",
    "contentful-management": "^12.8.0",
    "eslint": "10.3.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "16.2.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "8.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-helpers": "^2.0.1",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-next": "^0.0.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-storybook": "10.3.6",
    "globals": "16.5.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-styled-components": "7.4.0",
    "lint-staged": "17.0.2",
    "next-sitemap": "^4.2.3",
    "prettier": "3.8.3",
    "storybook": "10.3.6",
    "storybook-dark-mode": "^5.0.0",
    "ts-jest": "29.4.9",
    "ts-node": "^10.9.2",
    "tsc-alias": "1.8.17",
    "typescript-eslint": "8.59.4",
    "wait-on": "^9.0.10"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      [
        "eslint",
        "prettier --write"
      ],
      "git add"
    ],
    "**/*.{md,mdx,json}": [
      [
        "eslint",
        "prettier --write"
      ],
      "git add"
    ]
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "yarn@4.9.1"
}
