{
  "name": "website-test",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "yarn lint:fix && yarn build:compile && yarn build:sitemap",
    "build-storybook": "storybook build",
    "build:compile": "next build",
    "build:config": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:sitemap": "NODE_OPTIONS='--no-deprecation' next-sitemap --config next-sitemap.config.js",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --build-script-name build-storybook --exit-zero-on-changes",
    "dev": "NODE_OPTIONS='--no-deprecation' next dev",
    "lint": "eslint --ext ts,tsx . --quiet",
    "lint:fix": "eslint --fix --ext ts,tsx .",
    "postbuild": "NODE_OPTIONS='--no-deprecation' next-sitemap",
    "prettier:fix": "prettier --write .",
    "reset": "npx rimraf .yarn yarn.lock node_modules && touch yarn.lock && yarn install",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.2.0",
    "@opentelemetry/core": "^2.1.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@sentry/nextjs": "^10.22.0",
    "@types/node": "^22.18.6",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "airtable": "^0.12.2",
    "contentful": "^11.8.1",
    "dotenv": "^16.6.1",
    "next": "16.0.1",
    "next-seo": "^6.8.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-is": "19.2.0",
    "styled-components": "^6.1.19",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@cypress/request": "3.0.9",
    "@eslint/js": "^9.36.0",
    "@jest/globals": "^29.7.0",
    "@jest/types": "^29.6.3",
    "@next/eslint-plugin-next": "16.0.1",
    "@storybook/addon-docs": "^9.1.13",
    "@storybook/addon-links": "^9.1.8",
    "@storybook/addon-onboarding": "^9.1.8",
    "@storybook/addon-vitest": "9.1.15",
    "@storybook/nextjs": "^9.1.16",
    "@storybook/nextjs-vite": "^9.1.8",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/cypress": "^1.1.6",
    "@types/identity-obj-proxy": "^3",
    "@types/jest": "^29.5.14",
    "@types/styled-components": "5.1.34",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "chromatic": "^11.29.0",
    "cypress": "^14.5.4",
    "eslint": "^9.37.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "16.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-helpers": "^2.0.1",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-next": "^0.0.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^9.1.8",
    "globals": "^16.5.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-styled-components": "^7.2.0",
    "lint-staged": "^15.5.2",
    "next-sitemap": "^4.2.3",
    "playwright": "^1.55.1",
    "prettier": "^3.6.2",
    "storybook": "^9.1.8",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript-eslint": "^8.46.0",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      [
        "eslint",
        "prettier --write"
      ],
      "git add"
    ],
    "**/*.{md,mdx,json}": [
      [
        "eslint",
        "prettier --write"
      ],
      "git add"
    ]
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "packageManager": "yarn@4.9.1+sha512.f95ce356460e05be48d66401c1ae64ef84d163dd689964962c6888a9810865e39097a5e9de748876c2e0bf89b232d583c33982773e9903ae7a76257270986538",
  "resolutions": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2"
  }
}
