{
  "name": "website-test",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "yarn lint:fix && yarn build:compile && yarn build:sitemap",
    "build:config": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:compile": "next build",
    "build:sitemap": "next-sitemap --config next-sitemap.config.js",
    "dev": "next dev --turbopack",
    "lint": "eslint --ext ts,tsx . --quiet",
    "lint:fix": "eslint --fix --ext ts,tsx .",
    "postbuild": "next-sitemap",
    "prettier:fix": "prettier --write .",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --build-script-name build-storybook --exit-zero-on-changes"
  },
  "dependencies": {
    "@babel/runtime": "^7.27.1",
    "@babel/runtime-corejs3": "^7.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.0.1",
    "@opentelemetry/sdk-trace-base": "^2.0.1",
    "@sentry/nextjs": "^9.22.0",
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "airtable": "^0.12.2",
    "contentful": "^11.5.23",
    "dotenv": "^16.5.0",
    "next": "^15.3.1",
    "next-seo": "^6.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "18.3.1",
    "styled-components": "^6.1.16",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/eslint-parser": "7.27.1",
    "@babel/plugin-transform-runtime": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@chromatic-com/storybook": "^3",
    "@cypress/request": "3.0.8",
    "@eslint/js": "^9.27.0",
    "@jest/globals": "^29.7.0",
    "@jest/types": "^29.6.3",
    "@next/eslint-plugin-next": "^15.3.2",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/addon-onboarding": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/experimental-addon-test": "^8.6.14",
    "@storybook/experimental-nextjs-vite": "8.6.14",
    "@storybook/nextjs": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@testing-library/cypress": "^10.0.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^13.0.0",
    "@types/babel__plugin-transform-runtime": "^7",
    "@types/babel__preset-env": "^7",
    "@types/cypress": "^1.1.6",
    "@types/identity-obj-proxy": "^3",
    "@types/jest": "^29.5.14",
    "@types/styled-components": "5.1.34",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/browser": "^3.1.4",
    "@vitest/coverage-v8": "^3.1.4",
    "babel-jest": "^29.7.0",
    "babel-plugin-styled-components": "^2.1.4",
    "chromatic": "^11.29.0",
    "cypress": "^14.4.0",
    "eslint": "^9.27.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "15.3.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-html": "^8.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-import-helpers": "^2.0.1",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-next": "^0.0.0",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^0.12.0",
    "globals": "^16.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-styled-components": "^7.2.0",
    "lint-staged": "^15.5.2",
    "next-sitemap": "^4.2.3",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "storybook": "^8.6.14",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      [
        "eslint",
        "prettier --write"
      ],
      "git add"
    ],
    "**/*.{md,mdx,json}": [
      [
        "eslint",
        "prettier --write"
      ],
      "git add"
    ]
  },
  "resolutions": {
    "styled-components": "5",
    "@types/react": "18.3.22",
    "@types/react-dom": "18.3.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
